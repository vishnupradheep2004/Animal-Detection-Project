# Environment Configuration File
# Copy this to .env and fill in your values

# ============================================
# TELEGRAM CONFIGURATION
# ============================================
# Get your bot token from BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Get your chat ID by sending a message to your bot
# Then visit https://api.telegram.org/botYOUR_TOKEN/getUpdates
TELEGRAM_CHAT_ID=your_chat_id_here

# ============================================
# CAMERA CONFIGURATION
# ============================================
# Camera type: 'webcam' or 'rtsp'
CAMERA_TYPE=webcam

# RTSP URL (if using RTSP camera)
# Example: rtsp://192.168.1.100:554/stream
RTSP_URL=

# Camera index for webcam (usually 0 for primary camera)
CAMERA_INDEX=0

# ============================================
# MODEL CONFIGURATION
# ============================================
# Path to YOLOv8 weights
MODEL_PATH=runs/detect/train/weights/best.pt

# Confidence threshold for detections (0.0-1.0)
MODEL_CONFIDENCE=0.6

# ============================================
# ALERT CONFIGURATION
# ============================================
# Minimum confidence for sending alerts
ALERT_CONFIDENCE_THRESHOLD=0.7

# Maximum alerts per day
ALERT_DAILY_LIMIT=50

# Maximum alerts per hour
ALERT_HOURLY_LIMIT=10

# ============================================
# STORAGE CONFIGURATION
# ============================================
# Directory for snapshots
SNAPSHOTS_DIR=snapshots

# Directory for logs
LOGS_DIR=logs

# Maximum storage in GB before cleanup
MAX_STORAGE_GB=10

# Days to retain snapshots before cleanup
RETENTION_DAYS=7

# ============================================
# DEPLOYMENT CONFIGURATION
# ============================================
# Environment: development, staging, or production
ENVIRONMENT=production

# Debug mode (true/false)
DEBUG=false

# Application name
APP_NAME=Animal Detection System

# Application version
APP_VERSION=1.0.0
